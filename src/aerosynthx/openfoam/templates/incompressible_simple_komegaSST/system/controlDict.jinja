/*--------------------------------*- C++ -*----------------------------------*\\
| AeroSynthX-generated OpenFOAM dictionary                                    |
\\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     simpleFoam;

startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         {{ end_time }};
deltaT          1;

writeControl    timeStep;
writeInterval   {{ write_interval }};

purgeWrite      0;
writeFormat     ascii;
writePrecision  8;
writeCompression off;

timeFormat      general;
timePrecision   6;
runTimeModifiable true;

functions
{
    forceCoeffs
    {
        type            forceCoeffs;
        libs            ("libforces.so");
        writeControl    timeStep;
        writeInterval   10;
        log             yes;
        patches         ("airfoil");
        p               p;
        U               U;
        rho             rhoInf;
        rhoInf          {{ rho }};
        log             true;
        CofR            (0.25 0 0);
        liftDir         (0 1 0);
        dragDir         (1 0 0);
        pitchAxis       (0 0 1);
        magUInf         {{ ux }};
        lRef            {{ lRef }};
        Aref            {{ Aref }};
    }
}

// ************************************************************************* //
