# AeroSynthX — example environment variables.
# Copy to `.env` for local development. Never commit `.env`.
#
# No env vars are required in Phase 0. Real entries appear from Phase 3+.

# --- LLM provider (Phase 3+) ---
# AEROSYNTHX_LLM_PROVIDER=openai
# AEROSYNTHX_LLM_MODEL=
# AEROSYNTHX_LLM_API_KEY=

# --- Persistence (Phase 5+) ---
# AEROSYNTHX_DB_URL=sqlite:///./local/aerosynthx.sqlite
# AEROSYNTHX_ARTIFACT_DIR=./local/artifacts

# --- Logging (Phase 7+) ---
# AEROSYNTHX_LOG_LEVEL=INFO
# AEROSYNTHX_LOG_FORMAT=json
